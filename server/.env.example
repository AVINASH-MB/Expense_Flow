PORT=4000
CORS_ORIGIN=http://localhost:8080

DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=expenseflow

JWT_SECRET=change-me-to-a-long-random-string
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL_DAYS=30

# Set to "true" in production (requires HTTPS) so the refresh cookie is sent only over TLS
COOKIE_SECURE=false
